<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#000">

    <!-- Main screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E1E1E"
            android:paddingHorizontal="12dp"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

            <ImageView
                android:id="@+id/ivMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                android:src="@drawable/sort"
                app:tint="@color/white"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:elevation="6dp"/>

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="September 01"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:fontFamily="@font/montserrat"/>

<!--            <ImageView-->
<!--                android:id="@+id/ivSearch"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_gravity="end"-->
<!--                android:layout_marginEnd="15dp"-->
<!--                android:src="@drawable/search"-->
<!--                android:contentDescription="Search"-->
<!--                android:tint="@android:color/white"/>-->
        </androidx.appcompat.widget.Toolbar>

        <!-- Content holder: overlays list and empty state on same rounded card -->
        <FrameLayout
            android:id="@+id/contentHolder"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp">

            <!-- Task list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHomeTasks"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_white_rounded"
                android:padding="12dp"
                android:clipToPadding="false"
                android:visibility="gone"/>

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_white_rounded"
                android:padding="16dp">

                <ImageView
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:src="@drawable/sun1"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="-50dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All clear"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:textSize="28sp"
                    android:layout_marginTop="-8dp"
                    android:fontFamily="@font/montserrat"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Looks like you have no task(s) for this day"
                    android:textColor="#777777"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/montserrat"/>

<!--                <Button-->
<!--                    android:id="@+id/btnAddTask"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:text="Add Task"-->
<!--                    android:textSize="12sp"-->
<!--                    android:padding="6dp"-->
<!--                    android:textColor="@android:color/white"-->
<!--                    android:backgroundTint="#1E1E1E"-->
<!--                    android:layout_marginTop="16dp"/>-->
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Side drawer (unchanged) -->
    <LinearLayout
        android:id="@+id/navigationDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000"
        android:layout_gravity="start"
        android:fitsSystemWindows="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivClose"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@android:color/white"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/tvDrawerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VERDI"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_centerInParent="true"/>

<!--            <ImageView-->
<!--                android:id="@+id/ivProfile"-->
<!--                android:layout_width="28dp"-->
<!--                android:layout_height="28dp"-->
<!--                android:layout_alignParentEnd="true"-->
<!--                android:src="@drawable/baseline_person_24"-->
<!--                android:tint="@android:color/white"/>-->
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:gravity="center_vertical"
            android:id="@+id/toggleSection">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"

                android:textColor="@android:color/white"
                android:textSize="16sp"/>

            <Switch
                android:id="@+id/switchDuty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="On Duty"
                android:checked="false"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#222"/>

        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigationView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            app:menu="@menu/nav_menu"/>
    </LinearLayout>
</androidx.drawerlayout.widget.DrawerLayout>
