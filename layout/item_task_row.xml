<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeColor="#F0F0F0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:padding="14dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top row: title + button -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tvTaskTitle"
                    android:text="Pickup: Shuwaikh"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="@color/black"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/tvTaskSub"
                    android:text="Block 2 • 10:30 AM"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:layout_marginTop="2dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <Button
                android:id="@+id/btnStarted"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="88dp"
                android:text="Started"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="14sp"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:backgroundTint="#86EFAC"
                android:textColor="#064E3B"
                android:layout_marginStart="12dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Thin divider inside the card -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"/>

        <!-- Optional footer row (icons, status chips, etc.) -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvFooter"
                android:text="COD • KD 3.250"
                android:textSize="12sp"
                android:textColor="#7A7A7A"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
