<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Map in background -->
    <com.esri.arcgisruntime.mapping.view.MapView
        android:id="@+id/paciMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/darker_gray"
        android:visibility="gone"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/white"
        android:padding="20dp">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/baseline_arrow_back_3"
            android:padding="4dp"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <TextView
            android:id="@+id/tvTaskId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="572736861"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/black" />
    </LinearLayout>

    <!-- BottomSheet -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/transparent"
        app:behavior_peekHeight="140dp"
        app:behavior_hideable="false"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="5dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_drag_handle"
                android:layout_marginBottom="12dp"/>

            <!-- Task Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Time + Status -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tvTaskTimeType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12:53 pm - Pickup"
                            android:textSize="16sp"
                            android:textColor="@color/black" />

                        <TextView
                            android:id="@+id/tvTaskStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Started"
                            android:padding="6dp"
                            android:textColor="@color/started_text"
                            android:background="@drawable/bg_status_started"
                            android:layout_marginStart="12dp"/>
                    </LinearLayout>

                    <!-- Address + Call/WhatsApp/Direction -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/tvTaskAddress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/black"
                            android:text="Sharq - Block 4 - Parcel 30"
                            android:textSize="15sp"
                            android:drawableLeft="@drawable/baseline_location_on_24"
                            android:drawablePadding="6dp" />

                        <ImageView
                            android:id="@+id/ivCall"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/baseline_local_phone_1"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:tint="@android:color/holo_green_dark"
                            android:layout_marginEnd="8dp" />

                        <ImageView
                            android:id="@+id/ivWhatsApp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_whatsapp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:tint="@android:color/holo_green_dark"/>

                        <!-- Direction Arrow -->
                        <ImageView
                            android:id="@+id/ivDirection"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_direction"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"
                            android:tint="@color/teal_700"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>

                    <!-- Extra Info -->
                    <TextView
                        android:id="@+id/tvTaskDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Task from Verdi, Payment Type: Cash, Order Amount: 9.999 KD"
                        android:textSize="14sp"
                        android:layout_marginTop="10dp"
                        android:drawableLeft="@drawable/ic_info"
                        android:drawablePadding="6dp"
                        android:textColor="@color/black"/>

                    <!-- Order ID -->
                    <TextView
                        android:id="@+id/tvOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORDER ID #19/905/12"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:drawableLeft="@drawable/baseline_check_box_24"
                        android:drawablePadding="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Pickup Stage -->
        <LinearLayout
            android:id="@+id/layoutPickupStage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/white">

            <TextView
                android:id="@+id/tvPickupAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sharq - Block 4 - Parcel 30 (Pickup)"
                android:textSize="15sp"
                android:textColor="@android:color/black"/>

            <!-- Swipe button for Pickup -->
            <com.ncorti.slidetoact.SlideToActView
                android:id="@+id/swipePickupArrive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:text="Arrive"
                app:outer_color="@color/teal_700"
                app:inner_color="@color/white"
                app:text_size="16sp"
                app:slider_icon="@drawable/ic_arrive" />
        </LinearLayout>

        <!-- Delivery Stage (hidden initially) -->
        <LinearLayout
            android:id="@+id/layoutDeliveryStage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/white"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvDeliveryAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salmiya - Block 5 - Parcel 20 (Delivery)"
                android:textSize="15sp"
                android:textColor="@android:color/black"/>

            <!-- Swipe to Arrive / then Complete (same control) -->
            <com.ncorti.slidetoact.SlideToActView
                android:id="@+id/swipeDeliveryArrive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:text="Arrive at Dropoff"
                app:outer_color="@color/teal_700"
                app:inner_color="@color/white"
                app:text_size="16sp"
                app:slider_icon="@drawable/ic_arrive" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===================================================== -->
    <!-- ✅ FULL SCREEN UPDATING OVERLAY (spinner + blocker)     -->
    <!-- ===================================================== -->
    <FrameLayout
        android:id="@+id/updateOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:background="#66000000">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressUpdate"
                android:layout_width="48dp"
                android:layout_height="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Updating..."
                android:textSize="14sp"
                android:textColor="@android:color/white" />
        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
