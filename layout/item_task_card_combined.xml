<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardUseCompatPadding="true"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeColor="#F0F0F0"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="#F0F0F0"
    android:fontFamily="@font/montserrat">

    <!-- ✅ FrameLayout lets us overlay the timer at top-right -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ✅ Main content -->
        <LinearLayout
            android:padding="9dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Header -->
            <TextView
                android:id="@+id/tvTxTitle"
                android:text="Assignment #12345"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat"/>

            <!-- Pickup row -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Pickup"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginRight="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"/>

                <TextView
                    android:id="@+id/tvPickupAddress"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#000000"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"/>

            <!-- Drop row -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Drop"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:textColor="@color/black"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginRight="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/montserrat"/>

                <TextView
                    android:id="@+id/tvDropAddress"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/montserrat"/>
            </LinearLayout>

            <!-- ✅ Footer: single full-width primary action -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimary"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:text="Accept"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="12sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                app:rippleColor="#22064E3B"
                android:fontFamily="@font/montserrat" />

        </LinearLayout>

        <!-- ✅ Timer badge (top-right) -->
        <LinearLayout
            android:id="@+id/timerBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_timer_badge">

            <ImageView
                android:id="@+id/ivTimer"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_timer"
                android:contentDescription="Timer" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="30s"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#333333"
                android:fontFamily="@font/montserrat" />
        </LinearLayout>

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>
